{
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"],
    "AllowedRequest": ["http://localhost:5299"]
  },
  "Jwt": {
    "Issuer": "TraineeManagementApi",
    "Audience": "TraineeManagementClient",
    "ExpiryMinutes": 60
  },
  "FileStorage": {
    "MaxFileSizeInBytes": 10485760,
    "AllowedExtensions": [ ".pdf", ".docx", ".png", ".jpg", ".jpeg", ".txt", ".zip" ],
    "MagicNumbers": {
      ".pdf": "25504446",
      ".png": "89504E47",
      ".jpg": "FFD8FF",
      ".jpeg": "FFD8FF",
      ".zip": "504B0304",
      ".docx": "504B0304",
      ".txt": "EFBBBF"
    },
    "BasePath": ""
  },
  "Redis": {
    "ConnectionString": ""
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "myvhost"
  },
  "DirectoryService": {
    "BaseUrl": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  }
}